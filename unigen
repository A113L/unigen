    # ---------- Scrollable Canvas ----------
    def _build_scrollable_container(self):
        self.main_canvas = tk.Canvas(self.root, bg=self.theme["bg"], highlightthickness=0)
        self.main_canvas.pack(side=tk.LEFT, fill=tk.BOTH, expand=True)

        self.scrollbar = tk.Scrollbar(
            self.root, orient="vertical", command=self.main_canvas.yview,
            bg=self.theme["card_border"], activebackground=self.theme["input_bg"],
            troughcolor=self.theme["trough"], highlightthickness=0
        )
        self.scrollbar.pack(side=tk.RIGHT, fill=tk.Y)
        self.main_canvas.configure(yscrollcommand=self.scrollbar.set)

        self.main_frame = tk.Frame(self.main_canvas, bg=self.theme["bg"])
        self.main_canvas_window = self.main_canvas.create_window((0, 0), window=self.main_frame, anchor="nw")

        self.main_frame.bind("<Configure>", self.on_frame_configure)
        self.main_canvas.bind("<Configure>", self.on_canvas_configure)

        self.main_canvas.bind_all("<MouseWheel>", self.on_mousewheel)
        self.main_canvas.bind_all("<Button-4>", self.on_mousewheel)
        self.main_canvas.bind_all("<Button-5>", self.on_mousewheel)

    def on_frame_configure(self, event=None):
        self.main_canvas.configure(scrollregion=self.main_canvas.bbox("all"))

    def on_canvas_configure(self, event=None):
        self.main_canvas.itemconfig(self.main_canvas_window, width=event.width)

    def on_mousewheel(self, event):
        if isinstance(event.widget, tk.Text):
            return
        if event.num == 4 or event.delta > 0:
            self.main_canvas.yview_scroll(-1, "units")
        elif event.num == 5 or event.delta < 0:
            self.main_canvas.yview_scroll(1, "units")

    # ---------- Theme Switch ----------
    def switch_theme(self):
        new_theme = "light" if self.theme_name == "dark" else "dark"
        self.theme_name = new_theme
        self.theme = THEMES[new_theme]
        self.root.configure(bg=self.theme["bg"])

        # Preserve dynamic text content
        saved_output = self.output_text.get(1.0, tk.END) if hasattr(self, "output_text") and self.output_text else ""
        saved_enc_result = self.enc_result_text.get(1.0, tk.END) if hasattr(self, "enc_result_text") and self.enc_result_text else ""
        saved_enc_status = self.enc_status.cget("text") if hasattr(self, "enc_status") else ""
        saved_enc_status_fg = self.enc_status.cget("fg") if hasattr(self, "enc_status") else self.theme["text_secondary"]
        saved_dec_status = self.dec_status.cget("text") if hasattr(self, "dec_status") else ""
        saved_dec_status_fg = self.dec_status.cget("fg") if hasattr(self, "dec_status") else self.theme["text_secondary"]
        saved_shred_status = self.shred_status.cget("text") if hasattr(self, "shred_status") else ""
        saved_shred_status_fg = self.shred_status.cget("fg") if hasattr(self, "shred_status") else self.theme["text_secondary"]

        # Rebuild
        self.main_frame.destroy()
        self.main_canvas.destroy()
        self.scrollbar.destroy()

        self._build_scrollable_container()
        self.build_ui()

        # Restore text areas
        if saved_output and hasattr(self, "output_text"):
            self.output_text.config(state=tk.NORMAL)
            self.output_text.delete(1.0, tk.END)
            self.output_text.insert(tk.END, saved_output)
            self.output_text.config(state=tk.DISABLED)
            if self.generated_passwords:
                self.copy_btn.config(state=tk.NORMAL)
                self.save_btn.config(state=tk.NORMAL)

        if saved_enc_result and hasattr(self, "enc_result_text"):
            self.enc_result_text.config(state=tk.NORMAL)
            self.enc_result_text.delete(1.0, tk.END)
            self.enc_result_text.insert(tk.END, saved_enc_result)
            self.enc_result_text.config(state=tk.DISABLED)
            if self.last_encrypted_b64:
                self.enc_copy_btn.config(state=tk.NORMAL)
                self.enc_save_btn.config(state=tk.NORMAL)

        if hasattr(self, "enc_status"):
            self.enc_status.config(text=saved_enc_status, fg=saved_enc_status_fg)
        if hasattr(self, "dec_status"):
            self.dec_status.config(text=saved_dec_status, fg=saved_dec_status_fg)
        if hasattr(self, "shred_status"):
            self.shred_status.config(text=saved_shred_status, fg=saved_shred_status_fg)

        self.update_pool_stats()
        self.show_tab(self.active_tab)
        self.check_enc_ready()
        self.check_dec_ready()
        self.check_shred_ready()

