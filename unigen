    # ---------- Event handlers ----------
    def on_len_change(self, *args):
        try:
            v = self.len_var.get()
            if v < 8:
                self.len_var.set(8)
            elif v > 128:
                self.len_var.set(128)
            self.current_values["length"] = self.len_var.get()
        except Exception:
            pass

    def on_cnt_change(self, *args):
        try:
            v = self.cnt_var.get()
            if v < 1:
                self.cnt_var.set(1)
            elif v > 10000:
                self.cnt_var.set(10000)
            self.current_values["count"] = self.cnt_var.get()
        except Exception:
            pass

    def on_enc_pwd_change(self):
        self.current_values["enc_pwd"] = self.enc_pwd_var.get()
        self.check_enc_ready()
        self._reset_pwd_autoclear_timer("enc")

    def on_dec_pwd_change(self):
        self.current_values["dec_pwd"] = self.dec_pwd_var.get()
        self.check_dec_ready()
        self._reset_pwd_autoclear_timer("dec")

    # ---------- Passphrase auto-clear ----------
    def _on_pwd_autoclear_toggle(self, which):
        """Called when the enc/dec 'clear passphrase after Ns' checkbox is toggled."""
        var = getattr(self, f"{which}_pwd_autoclear_var")
        self.current_values[f"{which}_pwd_autoclear"] = var.get()
        self._reset_pwd_autoclear_timer(which)

    def _reset_pwd_autoclear_timer(self, which):
        """(Re)start the inactivity countdown that clears the enc/dec passphrase
        field from memory. Called on every keystroke, so typing resets the clock;
        the field is only cleared after N seconds with no further changes."""
        attr = f"_{which}_pwd_clear_after_id"
        pending_id = getattr(self, attr, None)
        if pending_id:
            try:
                self.root.after_cancel(pending_id)
            except Exception:
                pass
            setattr(self, attr, None)

        enabled_var = getattr(self, f"{which}_pwd_autoclear_var", None)
        if enabled_var is None or not enabled_var.get():
            return

        pwd_var = getattr(self, f"{which}_pwd_var", None)
        if pwd_var is None or not pwd_var.get():
            return

        seconds = int(self.current_values.get("pwd_autoclear_seconds", 30))
        new_id = self.root.after(seconds * 1000, lambda: self._clear_pwd_field(which))
        setattr(self, attr, new_id)

    def _clear_pwd_field(self, which):
        """Wipe the enc/dec passphrase Entry's backing StringVar from memory."""
        setattr(self, f"_{which}_pwd_clear_after_id", None)
        pwd_var = getattr(self, f"{which}_pwd_var", None)
        if pwd_var is None or not pwd_var.get():
            return
        pwd_var.set("")
        status_label = getattr(self, f"{which}_status", None)
        if status_label is not None:
            try:
                status_label.config(
                    text=f"Passphrase cleared from memory after {self.current_values.get('pwd_autoclear_seconds', 30)}s of inactivity.",
                    fg=self.theme["text_secondary"]
                )
            except Exception:
                pass

    def get_active_pool(self):
        pool = ""
        for name, data in CHAR_SETS.items():
            if self.charset_vars[name].get():
                pool += data["chars"]
        seen = set()
        result = []
        for c in pool:
            if c not in seen:
                seen.add(c)
                result.append(c)
        return "".join(result)

    def update_pool_stats(self):
        pool = self.get_active_pool()
        try:
            length = self.len_var.get()
        except Exception:
            length = 20
        pool_size = len(pool)

        self.stat_cards["pool"].config(text=f"{pool_size:,}")
        entropy = calculate_entropy(length, pool_size)
        self.stat_cards["entropy"].config(text=f"{entropy:.1f} bits")
        rating, color_key = rate_entropy(entropy)
        self.stat_cards["strength"].config(text=rating, fg=self.theme[color_key])

        if pool_size == 0:
            self.warn_label.pack(anchor=tk.W, padx=16, pady=(0, 6))
            self.gen_btn.config(state=tk.DISABLED)
        else:
            self.warn_label.pack_forget()
            self.gen_btn.config(state=tk.NORMAL)

    def generate_passwords(self):
        if self.gen_running:
            return
        pool = self.get_active_pool()
        try:
            length = self.len_var.get()
            count = self.cnt_var.get()
        except Exception:
            return
        if not pool or length <= 0 or count <= 0:
            return

        self.gen_running = True
        self.output_text.config(state=tk.NORMAL)
        self.output_text.delete(1.0, tk.END)

        if count > 100:
            self.progress.pack(fill=tk.X, pady=(8, 3))
            self.prog_label.pack(anchor=tk.W)
            self.root.update()

        self.generated_passwords = []
        chunk = max(1, count // 100)
        lines = []

        for i in range(count):
            pwd = generate_password(length, pool)
            self.generated_passwords.append(pwd)
            lines.append(f"#{i + 1}: {pwd}")

            if count > 100 and ((i + 1) % chunk == 0 or i == count - 1):
                pct = int((i + 1) / count * 100)
                self.progress["value"] = pct
                self.prog_label.config(text=f"Generating\u2026 {pct}% ({i + 1:,}/{count:,})")
                self.root.update_idletasks()

        self.output_text.insert(tk.END, "\n".join(lines) + "\n")

        if count > 100:
            self.progress.pack_forget()
            self.prog_label.pack_forget()

        self.output_text.config(state=tk.DISABLED)
        self.copy_btn.config(state=tk.NORMAL)
        self.save_btn.config(state=tk.NORMAL)
        self.gen_running = False

    def copy_all_passwords(self):
        if not self.generated_passwords:
            return
        text = "\n".join(self.generated_passwords)
        self.copy_to_clipboard(text, status_label=self.gen_copy_status)

    def save_passwords(self):
        if not self.generated_passwords:
            return
        path = filedialog.asksaveasfilename(
            defaultextension=".txt",
            filetypes=[("Text files", "*.txt"), ("All files", "*.*")],
            initialfile=f"passwords_{len(self.generated_passwords)}.txt"
        )
        if path:
            try:
                with open(path, "w", encoding="utf-8") as f:
                    f.write("\n".join(self.generated_passwords))
                self.last_saved_password_path = path
                self.encrypt_shred_btn.config(state=tk.NORMAL)
                messagebox.showinfo("Saved", f"Saved to:\n{path}")
            except Exception as e:
                messagebox.showerror("Error", str(e))

    # ---------- One-click: encrypt the saved password list, then shred original ----------
    def encrypt_and_shred_password_file(self):
        if not CRYPTO_AVAILABLE:
            messagebox.showerror("Missing Dependency", "Install 'cryptography' to use this feature:\npip install cryptography")
            return

        path = self.last_saved_password_path
        if not path or not os.path.exists(path):
            if self.generated_passwords:
                self.save_passwords()
                path = self.last_saved_password_path
            if not path or not os.path.exists(path):
                messagebox.showwarning("No file", "Save the password list to a file first.")
                return

        pwd = simpledialog.askstring(
            "Encryption Passphrase",
            "Enter a passphrase (min 8 characters) to protect this password file:",
            show="•", parent=self.root
        )
        if not pwd or len(pwd) < 8:
            if pwd is not None:
                messagebox.showwarning("Too short", "Passphrase must be at least 8 characters.")
            return

        try:
            with open(path, "rb") as f:
                original_data = f.read()

            salt = os.urandom(16)
            iv = os.urandom(12)
            key = self.derive_key(pwd, salt)
            aesgcm = AESGCM(key)
            ct = aesgcm.encrypt(iv, original_data, None)
            combined = salt + iv + ct

            enc_path = path + ".enc"
            with open(enc_path, "w", encoding="ascii") as f:
                f.write(base64.b64encode(combined).decode("ascii"))

            # Verify: the encrypted file must decrypt back to the exact original bytes
            # before the plaintext is destroyed.
            with open(enc_path, "r", encoding="ascii") as f:
                check_b64 = f.read().strip()
            check_combined = base64.b64decode(check_b64)
            check_salt, check_iv, check_ct = check_combined[:16], check_combined[16:28], check_combined[28:]
            check_key = self.derive_key(pwd, check_salt)
            decrypted_back = AESGCM(check_key).decrypt(check_iv, check_ct, None)

            if decrypted_back == original_data:
                result = self.shred_file(path)
                if result == "fallback":
                    messagebox.showwarning(
                        "Encrypted, deletion not fully verified",
                        f"Encrypted to:\n{enc_path}\n\n"
                        "The original file was removed, but the secure multi-pass overwrite "
                        "could not be confirmed. If this matters, use a dedicated secure-erase tool."
                    )
                else:
                    messagebox.showinfo(
                        "Done",
                        f"Encrypted to:\n{enc_path}\n\nOriginal plaintext securely shredded:\n{path}"
                    )
                self.last_saved_password_path = None
                self.encrypt_shred_btn.config(state=tk.DISABLED)
            else:
                messagebox.showerror(
                    "Verification failed",
                    "The encrypted file did not verify correctly \u2014 the original was NOT deleted."
                )
        except Exception as e:
            messagebox.showerror("Error", str(e))

    # ---------- Encryption (generic file protector) ----------
    def browse_encrypt_file(self):
        path = filedialog.askopenfilename(title="Select file to encrypt")
        if path:
            self.enc_file_path.set(path)
            self.current_values["enc_file"] = path
            self.check_enc_ready()

    def browse_decrypt_file(self):
        path = filedialog.askopenfilename(
            title="Select encrypted file",
            filetypes=[("Encrypted files", "*.enc"), ("All files", "*.*")]
        )
        if path:
            self.dec_file_path.set(path)
            self.current_values["dec_file"] = path
            self.check_dec_ready()

    def check_enc_ready(self):
        ready = bool(self.enc_file_path.get() and len(self.enc_pwd_var.get()) >= 8)
        self.enc_btn.config(state=tk.NORMAL if ready else tk.DISABLED)

    def check_dec_ready(self):
        ready = bool(self.dec_file_path.get() and self.dec_pwd_var.get())
        self.dec_btn.config(state=tk.NORMAL if ready else tk.DISABLED)

    def derive_key(self, password, salt):
        kdf = PBKDF2HMAC(algorithm=hashes.SHA256(), length=32, salt=salt, iterations=600_000)
        return kdf.derive(password.encode("utf-8"))

    def encrypt_file(self):
        path = self.enc_file_path.get()
        pwd = self.enc_pwd_var.get()
        if not path or len(pwd) < 8:
            return

        self.enc_status.config(text="Encrypting\u2026", fg=self.theme["accent"])
        self.root.update()

        try:
            with open(path, "rb") as f:
                data = f.read()

            salt = os.urandom(16)
            iv = os.urandom(12)
            key = self.derive_key(pwd, salt)
            aesgcm = AESGCM(key)
            ct = aesgcm.encrypt(iv, data, None)
            combined = salt + iv + ct
            b64 = base64.b64encode(combined).decode("ascii")

            self.last_encrypted_b64 = b64
            self.last_encrypted_filename = Path(path).name + ".enc"

            self.enc_result_text.config(state=tk.NORMAL)
            self.enc_result_text.delete(1.0, tk.END)
            preview = b64[:1200] + "..." if len(b64) > 1200 else b64
            self.enc_result_text.insert(tk.END, preview + "\n")
            if len(b64) > 1200:
                self.enc_result_text.insert(tk.END, f"\n[Total length: {len(b64)} characters \u2014 use Copy or Save for full data]\n")
            self.enc_result_text.config(state=tk.DISABLED)

            self.enc_copy_btn.config(state=tk.NORMAL)
            self.enc_save_btn.config(state=tk.NORMAL)

            status_msg = "Encryption complete. Use Copy or Save below."
            status_fg = self.theme["success"]

            if self.shred_after_enc_var.get():
                try:
                    # Verify the ciphertext actually decrypts back before touching the original.
                    verify_key = self.derive_key(pwd, salt)
                    decrypted_back = AESGCM(verify_key).decrypt(iv, ct, None)
                    if decrypted_back == data:
                        result = self.shred_file(path)
                        if result == "fallback":
                            status_msg = "Encrypted & verified. Original deleted (overwrite could not be confirmed)."
                            status_fg = self.theme["warning"]
                            messagebox.showwarning(
                                "Deletion not fully verified",
                                "The original file was removed, but the secure multi-pass overwrite "
                                "could not be confirmed. Consider a dedicated secure-erase tool for "
                                "highly sensitive data."
                            )
                        else:
                            status_msg = "Encryption complete. Original securely shredded after verification."
                    else:
                        status_msg = "Encrypted, but verification failed \u2014 original was NOT deleted."
                        status_fg = self.theme["danger"]
                except Exception as e:
                    status_msg = f"Encrypted, but shred step failed: {e}"
                    status_fg = self.theme["warning"]

            self.enc_status.config(text=status_msg, fg=status_fg)
        except Exception as e:
            self.enc_status.config(text=f"Error: {str(e)}", fg=self.theme["danger"])
            messagebox.showerror("Error", str(e))

    def copy_encrypted(self):
        if not self.last_encrypted_b64:
            return
        self.copy_to_clipboard(self.last_encrypted_b64, status_label=self.enc_status)

    def save_encrypted(self):
        if not self.last_encrypted_b64:
            return
        path = filedialog.asksaveasfilename(
            defaultextension=".enc",
            filetypes=[("Encrypted files", "*.enc"), ("All files", "*.*")],
            initialfile=self.last_encrypted_filename or "encrypted.enc"
        )
        if path:
            try:
                with open(path, "w", encoding="ascii") as f:
                    f.write(self.last_encrypted_b64)
                self.enc_status.config(text=f"Saved: {path}", fg=self.theme["success"])
                messagebox.showinfo("Saved", f"Encrypted file saved.\n\n{path}")
            except Exception as e:
                messagebox.showerror("Error", str(e))

    def decrypt_file(self):
        path = self.dec_file_path.get()
        pwd = self.dec_pwd_var.get()
        if not path or not pwd:
            return

        self.dec_status.config(text="Decrypting\u2026", fg=self.theme["accent"])
        self.root.update()

        try:
            with open(path, "r", encoding="ascii") as f:
                b64 = f.read().strip()

            combined = base64.b64decode(b64)
            if len(combined) < 28:
                raise ValueError("Invalid file format")

            salt, iv, ct = combined[:16], combined[16:28], combined[28:]
            key = self.derive_key(pwd, salt)
            plain = AESGCM(key).decrypt(iv, ct, None)

            out_path = filedialog.asksaveasfilename(
                defaultextension="", filetypes=[("All files", "*.*")], initialfile=Path(path).stem
            )
            if out_path:
                with open(out_path, "wb") as f:
                    f.write(plain)
                self.dec_status.config(text=f"Saved: {out_path}", fg=self.theme["success"])
                messagebox.showinfo("Success", f"File decrypted and saved.\n\n{out_path}")
        except Exception:
            self.dec_status.config(text="Error: wrong password or corrupt file", fg=self.theme["danger"])
            messagebox.showerror("Error", "Decryption failed. Wrong password or corrupt file.")

    # ---------- Manual shred ----------
    def browse_shred_file(self):
        path = filedialog.askopenfilename(title="Select file to shred")
        if path:
            self.shred_file_path.set(path)
            self.check_shred_ready()

    def check_shred_ready(self):
        ready = bool(self.shred_file_path.get())
        self.shred_btn.config(state=tk.NORMAL if ready else tk.DISABLED)

    def shred_file_dialog(self):
        path = self.shred_file_path.get()
        if not path or not os.path.exists(path):
            return
        if not messagebox.askyesno("Confirm Shred", f"Permanently shred this file?\n\n{path}\n\nThis cannot be undone."):
            return
        self.shred_status.config(text="Shredding\u2026", fg=self.theme["accent"])
        self.root.update()
        try:
            result = self.shred_file(path)
            if result == "fallback":
                self.shred_status.config(
                    text="Deleted, but secure overwrite could not be confirmed.",
                    fg=self.theme["danger"]
                )
                messagebox.showwarning(
                    "Deletion not fully verified",
                    "The file was removed, but the secure multi-pass overwrite could not be "
                    "confirmed. Consider a dedicated secure-erase tool for highly sensitive data."
                )
            else:
                self.shred_status.config(text="File securely shredded.", fg=self.theme["success"])
                self.shred_file_path.set("")
                self.check_shred_ready()
                messagebox.showinfo("Shred Complete", "File has been securely deleted.")
        except Exception as e:
            self.shred_status.config(text=f"Error: {str(e)}", fg=self.theme["danger"])
            messagebox.showerror("Error", str(e))

    def shred_file(self, path, passes=3):
        """Securely shred a file. Returns 'secure' or 'fallback'."""
        if not os.path.exists(path):
            raise FileNotFoundError(f"File not found: {path}")
        if os.path.isdir(path):
            raise IsADirectoryError(f"Cannot shred a directory: {path}")

        size = os.path.getsize(path)
        overwrite_ok = True

        if size > 0:
            try:
                chunk_size = 1024 * 1024
                with open(path, "r+b") as f:
                    for _ in range(passes):
                        f.seek(0)
                        written = 0
                        while written < size:
                            to_write = min(chunk_size, size - written)
                            f.write(os.urandom(to_write))
                            written += to_write
                        f.flush()
                        try:
                            os.fsync(f.fileno())
                        except OSError:
                            pass
                    f.seek(0)
                    written = 0
                    while written < size:
                        to_write = min(chunk_size, size - written)
                        f.write(b'\x00' * to_write)
                        written += to_write
                    f.flush()
                    try:
                        os.fsync(f.fileno())
                    except OSError:
                        pass
            except Exception:
                overwrite_ok = False

        try:
            if sys.platform == "win32":
                os.chmod(path, stat.S_IWRITE)
            os.remove(path)
        except Exception as e:
            action = "overwritten" if overwrite_ok else "overwrite failed"
            raise RuntimeError(f"File {action} but could not be removed: {e}")

        return "secure" if overwrite_ok else "fallback"


