    # ---------- Event Handlers ----------
    def on_len_change(self, *args):
        try:
            v = self.len_var.get()
            if v < 8:
                self.len_var.set(8)
            elif v > 128:
                self.len_var.set(128)
        except Exception:
            pass
        self.current_values["length"] = self.len_var.get()
        self.update_pool_stats()

    def on_cnt_change(self, *args):
        try:
            v = self.cnt_var.get()
            if v < 1:
                self.cnt_var.set(1)
            elif v > 10000:
                self.cnt_var.set(10000)
        except Exception:
            pass
        self.current_values["count"] = self.cnt_var.get()

    def on_enc_pwd_change(self):
        self.current_values["enc_pwd"] = self.enc_pwd_var.get()
        self.check_enc_ready()

    def on_dec_pwd_change(self):
        self.current_values["dec_pwd"] = self.dec_pwd_var.get()
        self.check_dec_ready()

    def get_active_pool(self):
        pool = ""
        for name, data in CHAR_SETS.items():
            if self.charset_vars[name].get():
                pool += data["chars"]
        seen = set()
        result = []
        for c in pool:
            if c not in seen:
                seen.add(c)
                result.append(c)
        return "".join(result)

    def update_pool_stats(self):
        pool = self.get_active_pool()
        try:
            length = self.len_var.get()
        except Exception:
            length = 20
        pool_size = len(pool)

        self.stat_cards["pool"].config(text=f"{pool_size} chars")
        entropy = calculate_entropy(length, pool_size)
        self.stat_cards["entropy"].config(text=f"{entropy:.1f} bits")
        rating, color = rate_entropy(entropy)
        self.stat_cards["strength"].config(text=rating, fg=color)

        if pool_size == 0:
            self.warn_label.pack(anchor=tk.W, padx=18, pady=(0, 5))
            self.gen_btn.config(state=tk.DISABLED)
        else:
            self.warn_label.pack_forget()
            self.gen_btn.config(state=tk.NORMAL)

    def generate_passwords(self):
        if self.gen_running:
            return

        pool = self.get_active_pool()
        try:
            length = self.len_var.get()
            count = self.cnt_var.get()
        except Exception:
            return

        if not pool or length <= 0 or count <= 0:
            return

        self.gen_running = True
        self.output_text.config(state=tk.NORMAL)
        self.output_text.delete(1.0, tk.END)

        if count > 100:
            self.progress.pack(fill=tk.X, padx=18, pady=(0, 5))
            self.prog_label.pack(anchor=tk.W, padx=18)
            self.root.update()

        self.generated_passwords = []
        chunk = max(1, count // 100)

        for i in range(count):
            pwd = generate_password(length, pool)
            self.generated_passwords.append(pwd)
            self.output_text.insert(tk.END, f"#{i+1}: {pwd}\n")

            if count > 100 and ((i + 1) % chunk == 0 or i == count - 1):
                pct = int((i + 1) / count * 100)
                self.progress["value"] = pct
                self.prog_label.config(text=f"Generating... {pct}% ({i+1}/{count})")
                self.root.update_idletasks()

        if count > 100:
            self.progress.pack_forget()
            self.prog_label.pack_forget()

        self.output_text.config(state=tk.DISABLED)
        self.copy_btn.config(state=tk.NORMAL)
        self.save_btn.config(state=tk.NORMAL)
        self.gen_running = False

