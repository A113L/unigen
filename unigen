    def check_enc_ready(self):
        ready = bool(self.enc_file_path.get() and len(self.enc_pwd_var.get()) >= 8)
        self.enc_btn.config(state=tk.NORMAL if ready else tk.DISABLED)

    def check_dec_ready(self):
