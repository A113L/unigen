    # ---------- Clipboard ----------
    def copy_to_clipboard(self, text, status_label=None):
        """Copy text to the system clipboard, and — on every OS we can
        detect a mechanism for — tag it so well-behaved clipboard managers
        skip it entirely instead of storing/syncing it:

          Windows  Registers the "ExcludeClipboardContentFromMonitorProcessing",
                   "CanIncludeInClipboardHistory" and "CanUploadToCloudClipboard"
                   clipboard formats. These are the exact formats Windows'
                   own Clipboard History / Cloud Clipboard check, and the
                   same convention used by 1Password, Bitwarden and KeePass.
          macOS    Tags the pasteboard entry with the informal but widely
                   adopted nspasteboard.org marker types
                   (org.nspasteboard.ConcealedType / TransientType /
                   AutoGeneratedType), honoured by Paste, Maccy, Copied,
                   Flycut and others.
          Linux    (Opt-in, off by default) Offers the
                   "x-kde-passwordManagerHint" MIME type alongside the real
                   text on the X11 CLIPBOARD selection, which KDE Klipper
                   (and tools that mirror its convention, e.g.
                   KeePassXC/Bitwarden on Linux) checks before storing
                   clipboard history. Off by default because this relies on
                   a forked xclip/xsel helper process staying alive to
                   answer paste requests — some distros reap that orphan
                   after a few seconds, silently emptying the clipboard.
                   The default path instead keeps this app's own process as
                   the clipboard owner, which doesn't have that failure
                   mode.

        This is best-effort: a clipboard manager that implements none of
        these conventions (e.g. most GNOME extensions, generic Wayland
        history tools) will still see the copied text like any other app —
        there's no universal cross-desktop standard for this. When the
        OS-level exclusion can't be performed (missing tool, API failure),
        this transparently falls back to a plain clipboard copy so Copy
        never silently does nothing.
        """
        secured, note = False, ""
        try:
            if sys.platform == "win32":
                secured, note = self._copy_windows_excluded(text)
            elif sys.platform == "darwin":
                secured, note = self._copy_macos_excluded(text)
            elif self.current_values.get("linux_try_exclusion", False):
                # Linux/X11 has no system-level clipboard service the way
                # Windows and macOS do — xclip/xsel write by forking a
                # background helper that must stay alive to answer paste
                # requests. If a session manager or cgroup cleanup reaps
                # that orphaned helper (common on newer systemd distros),
                # the clipboard silently goes empty later even though the
                # write appeared to succeed. Because of that fragility this
                # path is opt-in; by default Linux uses the same category
                # of approach that already works reliably on Windows: our
                # own long-running process holds the clipboard directly.
                secured, note = self._copy_linux_excluded(text)
            else:
                secured, note = False, ""
        except Exception as e:
            secured, note = False, f"exclusion attempt raised {e}"

        if secured:
            # Don't just trust the exit code — some paths (a forked xclip
            # that gets reaped, an xclip build too old for the multi-target
            # syntax we pass, a DE that ignores the marker but still eats
            # the write) can report success while nothing pasteable is
            # actually left on the clipboard. Read it back and confirm.
            verified = False
            for _ in range(3):
                time.sleep(0.05)
                readback = self._read_clipboard_text()
                if readback == text:
                    verified = True
                    break
            if not verified:
                secured = False
                note = (note + "; " if note else "") + "could not verify native write, falling back"

        if not secured:
            # Fallback: plain Tkinter clipboard. Still copies correctly,
            # just without the manager-exclusion hints.
            try:
                self.root.clipboard_clear()
                self.root.clipboard_append(text)
                self.root.update()
            except Exception as e:
                if status_label is not None:
                    status_label.config(text=f"Copy failed: {e}", fg=self.theme["danger"])
                return
        # NOTE: when secured is True, the OS-native call above already put
        # the real text on the system clipboard as its primary format —
        # we deliberately do NOT also call Tkinter's clipboard_append here,
        # since that would take ownership again and silently strip the
        # exclusion formats we just attached.

        if status_label is not None:
            if secured:
                msg = "Copied — excluded from clipboard managers."
            elif note:
                msg = f"Copied (not excluded: {note})"
            else:
                msg = "Copied."
            if self.current_values.get("autoclear_enabled", True):
                secs = self.current_values.get("autoclear_seconds", 20)
                msg += f" Auto-clears in {secs}s."
            status_label.config(text=msg, fg=self.theme["accent"])

        # Schedule (or cancel) the auto-clear timer for this copy. Passing
        # status_label through means the "cleared" confirmation shows up
        # in the same place the "will clear in Ns" notice did, instead of
        # only in the dedicated Clear Clipboard status label elsewhere on
        # the tab (which is easy to miss and looks like the paste just
        # silently failed).
        self._schedule_autoclear(text, status_label=status_label)

    # --- Auto-clear (self-destructing clipboard) ---
    def _schedule_autoclear(self, text, status_label=None):
        """(Re)schedule the auto-clear timer for the text we just copied.
        Any previously pending timer is cancelled first, so only the most
        recent copy is ever waiting to be cleared.

        NOTE on limitations: there is no reliable, cross-platform way for a
        plain desktop app to detect "the user pasted this" — X11/Wayland,
        macOS and Windows all expose clipboard *change* notifications at
        best, not paste events tied to a specific target app, and sandboxed
        or permission-gated APIs make this worse, not better. So instead of
        pretending to detect paste, this clears the clipboard automatically
        after a fixed delay. Right before clearing, it re-checks the
        clipboard contents and only proceeds if they still match what this
        app put there — so if you've since copied something else, that new
        content is left alone.
        """
        if getattr(self, "_autoclear_after_id", None):
            try:
                self.root.after_cancel(self._autoclear_after_id)
            except Exception:
                pass
            self._autoclear_after_id = None
        self._autoclear_pending_text = None

        if not self.current_values.get("autoclear_enabled", True):
            return

        try:
            seconds = int(self.current_values.get("autoclear_seconds", 20))
        except Exception:
            seconds = 20
        seconds = max(5, min(300, seconds))

        self._autoclear_pending_text = text
        self._autoclear_after_id = self.root.after(
            seconds * 1000, lambda: self._autoclear_fire(text, status_label)
        )

    def _autoclear_fire(self, expected_text, status_label=None):
        """Timer callback: wipe the clipboard, but only if it still holds
        exactly what we copied — never something the user copied since."""
        self._autoclear_after_id = None
        self._autoclear_pending_text = None

        current = self._read_clipboard_text()
        # current is None when we couldn't determine the clipboard's
        # contents at all (every read path failed). In that case we still
        # go ahead and clear, since a stale secret sitting uncleared is the
        # worse failure mode of the two.
        if current is not None and current != expected_text:
            return

        self.clear_clipboard()
        msg = "Clipboard auto-cleared (timeout)."
        # Update the label the original copy notified through (e.g. "Copy
        # All"'s gen_copy_status), so the confirmation appears wherever the
        # "will auto-clear" notice did — not just in the separate Clear
        # Clipboard status label, which is easy to miss entirely.
        if status_label is not None:
            try:
                status_label.config(text=msg, fg=self.theme["success"])
            except Exception:
                pass
        if hasattr(self, "gen_clip_status"):
            self.gen_clip_status.config(text=msg, fg=self.theme["success"])
        if hasattr(self, "clip_status"):
            self.clip_status.config(text=msg, fg=self.theme["success"])

    def _read_clipboard_text(self):
        """Best-effort read-back of the current clipboard text.

        copy_to_clipboard() writes via OS-native calls (WinAPI / osascript /
        xclip / xsel / wl-copy) on most platforms rather than through
        Tkinter, specifically so it can attach the clipboard-manager
        exclusion markers. That means Tkinter's own clipboard_get() often
        can't see what was actually set (it only sees clipboard content
        Tkinter itself owns), so we read back using the same native tools
        first and only fall back to Tkinter's clipboard_get() last.

        Returns the text, "" if the clipboard is empty, or None if we
        couldn't determine the contents at all.
        """
        if sys.platform == "win32":
            try:
                import ctypes
                from ctypes import wintypes
                CF_UNICODETEXT = 13
                user32 = ctypes.WinDLL("user32", use_last_error=True)
                kernel32 = ctypes.WinDLL("kernel32", use_last_error=True)
                user32.GetClipboardData.restype = wintypes.HANDLE
                user32.GetClipboardData.argtypes = [wintypes.UINT]
                kernel32.GlobalLock.restype = wintypes.LPVOID
                kernel32.GlobalLock.argtypes = [wintypes.HGLOBAL]
                kernel32.GlobalUnlock.argtypes = [wintypes.HGLOBAL]
                if not user32.OpenClipboard(None):
                    raise RuntimeError("could not open clipboard")
                try:
                    h = user32.GetClipboardData(CF_UNICODETEXT)
                    if not h:
                        return ""
                    ptr = kernel32.GlobalLock(h)
                    if not ptr:
                        return ""
                    try:
                        return ctypes.wstring_at(ptr)
                    finally:
                        kernel32.GlobalUnlock(h)
                finally:
                    user32.CloseClipboard()
            except Exception:
                return None

        if sys.platform != "darwin":
            # Linux/X11: try Tkinter's OWN clipboard first. This matters a
            # lot here, not just as a nicety — when this app itself holds
            # the clipboard (the default path; see linux_try_exclusion),
            # shelling out to `xclip -o`/`xsel -o` instead would make that
            # new process ask OUR window for the data over the X11
            # selection protocol, while OUR main thread sits blocked inside
            # subprocess.run() waiting for that same process to return.
            # Neither side can proceed — a self-deadlock that freezes the
            # whole app until forcibly killed. Tkinter's own clipboard_get()
            # is answered in-process with no such round trip, so it's both
            # faster and safe to call from the main thread.
            try:
                return self.root.clipboard_get()
            except Exception:
                pass
            # Only reachable when Tk doesn't currently own the selection —
            # i.e. the opt-in linux_try_exclusion path, where xclip/xsel
            # itself is the owner and reading via the matching external
            # tool is the only way to see the content (and is safe, since
            # it's a genuinely separate process answering, not us).
            for cmd in (["xclip", "-selection", "clipboard", "-o"],
                        ["xsel", "--clipboard", "--output"],
                        ["wl-paste", "-n"]):
                if shutil.which(cmd[0]):
                    try:
                        out = subprocess.run(cmd, capture_output=True, check=True, timeout=1.0)
                        return out.stdout.decode("utf-8", errors="ignore")
                    except Exception:
                        continue
            return None

        # macOS: pbpaste talks to the system pasteboard service directly
        # (not to our own process), so no deadlock risk here — still
        # timeout-guarded defensively.
        try:
            if shutil.which("pbpaste"):
                out = subprocess.run(["pbpaste"], capture_output=True, check=True, timeout=1.0)
                return out.stdout.decode("utf-8", errors="ignore")
        except Exception:
            pass

        try:
            return self.root.clipboard_get()
        except Exception:
            return None

    def _copy_windows_excluded(self, text):
        """Write `text` to the Windows clipboard together with the marker
        formats Windows Clipboard History / Cloud Clipboard (and clipboard
        manager apps that follow the same convention) check before storing
        or syncing content. Pure ctypes — no pywin32 dependency required."""
        try:
            import ctypes
            from ctypes import wintypes
        except Exception as e:
            return False, f"ctypes unavailable ({e})"

        CF_UNICODETEXT = 13
        GMEM_MOVEABLE = 0x0002
        GMEM_ZEROINIT = 0x0040

        try:
            kernel32 = ctypes.WinDLL("kernel32", use_last_error=True)
            user32 = ctypes.WinDLL("user32", use_last_error=True)

            kernel32.GlobalAlloc.restype = wintypes.HGLOBAL
            kernel32.GlobalAlloc.argtypes = [wintypes.UINT, ctypes.c_size_t]
            kernel32.GlobalLock.restype = wintypes.LPVOID
            kernel32.GlobalLock.argtypes = [wintypes.HGLOBAL]
            kernel32.GlobalUnlock.argtypes = [wintypes.HGLOBAL]
            kernel32.GlobalFree.argtypes = [wintypes.HGLOBAL]

            user32.OpenClipboard.argtypes = [wintypes.HWND]
            user32.SetClipboardData.restype = wintypes.HANDLE
            user32.SetClipboardData.argtypes = [wintypes.UINT, wintypes.HANDLE]
            user32.RegisterClipboardFormatW.argtypes = [wintypes.LPCWSTR]
            user32.RegisterClipboardFormatW.restype = wintypes.UINT

            def _alloc_bytes(data: bytes):
                size = len(data) if data else 1
                h = kernel32.GlobalAlloc(GMEM_MOVEABLE | GMEM_ZEROINIT, size)
                if not h:
                    return None
                ptr = kernel32.GlobalLock(h)
                if not ptr:
                    kernel32.GlobalFree(h)
                    return None
                if data:
                    ctypes.memmove(ptr, data, len(data))
                kernel32.GlobalUnlock(h)
                return h
        except Exception as e:
            return False, f"WinAPI setup failed ({e})"

        if not user32.OpenClipboard(None):
            return False, "could not open clipboard"
        try:
            user32.EmptyClipboard()

            # Real text, so paste keeps working normally everywhere.
            buf = (text + "\0").encode("utf-16-le")
            h_text = _alloc_bytes(buf)
            if h_text:
                user32.SetClipboardData(CF_UNICODETEXT, h_text)
            else:
                return False, "could not allocate clipboard text buffer"

            # Marker formats. Presence alone is what matters; DWORD 0 is
            # the documented "false" payload for the history/cloud flags.
            zero_dword = (0).to_bytes(4, "little")
            markers = {
                "ExcludeClipboardContentFromMonitorProcessing": b"",
                "CanIncludeInClipboardHistory": zero_dword,
                "CanUploadToCloudClipboard": zero_dword,
            }
            for name, payload in markers.items():
                fmt_id = user32.RegisterClipboardFormatW(name)
                if not fmt_id:
                    continue
                h = _alloc_bytes(payload)
                if h:
                    user32.SetClipboardData(fmt_id, h)
        finally:
            user32.CloseClipboard()
        return True, ""

    def _copy_macos_excluded(self, text):
        """Write `text` to the macOS pasteboard tagged with the
        nspasteboard.org marker types, via a JXA (JavaScript for Automation)
        one-liner — this uses macOS's built-in ObjC bridge, so it needs no
        extra Python packages (no pyobjc)."""
        if not shutil.which("osascript"):
            return False, "osascript not found"
        script = (
            "ObjC.import('AppKit');"
            "function run(argv){"
            "var text=argv[0];"
            "var pb=$.NSPasteboard.generalPasteboard;"
            "pb.clearContents();"
            "pb.setStringForType(text,'public.utf8-plain-text');"
            "pb.setStringForType('','org.nspasteboard.ConcealedType');"
            "pb.setStringForType('','org.nspasteboard.TransientType');"
            "pb.setStringForType('','org.nspasteboard.AutoGeneratedType');"
            "}"
        )
        try:
            subprocess.run(
                ["osascript", "-l", "JavaScript", "-e", script, text],
                check=True, capture_output=True, timeout=2.0
            )
            return True, ""
        except Exception as e:
            return False, f"osascript exclusion failed ({e})"

    def _copy_linux_excluded(self, text):
        """Write `text` to the X11/Wayland clipboard, offering the
        'x-kde-passwordManagerHint' MIME type alongside the real text so
        KDE Klipper (and tools mirroring its convention) skip storing it in
        clipboard history. There is no equivalent convention honoured by
        GNOME's built-in clipboard tooling, so on GNOME-only systems this
        still copies fine — it just can't be hidden from history there."""
        data = text.encode("utf-8")

        # X11: a single xclip process can be told to answer TARGETS
        # requests for several MIME types from the same input, so we offer
        # the real text AND the KDE password-manager hint in one call.
        if shutil.which("xclip"):
            try:
                subprocess.run(
                    ["xclip", "-selection", "clipboard", "-t",
                     "UTF8_STRING,x-kde-passwordManagerHint", "-in"],
                    input=data, check=True, timeout=2.0
                )
                return True, ""
            except Exception:
                pass

        # xsel has no multi-target flag, so it can only offer plain text —
        # still copies correctly, just without the exclusion hint.
        if shutil.which("xsel"):
            try:
                subprocess.run(["xsel", "--clipboard", "--input"], input=data, check=True, timeout=2.0)
                return True, "xsel has no exclusion-hint support — install xclip for that."
            except Exception:
                pass

        # Wayland fallback. wl-copy only offers one MIME type per
        # invocation, so we prioritise correct pasting over exclusion here.
        if shutil.which("wl-copy"):
            try:
                subprocess.run(
                    ["wl-copy", "--type", "text/plain;charset=utf-8"],
                    input=data, check=True, timeout=2.0
                )
                return True, "wl-copy has no exclusion-hint support — install xclip for that."
            except Exception:
                pass

        return False, "no xclip/xsel/wl-copy found"

    # --- Robust clipboard wipe: Tkinter + OS-native fallbacks ---
    def clear_clipboard(self):
        """Clear the system clipboard on Windows, Linux and macOS."""
        # A manual clear (or the auto-clear timer itself) makes any pending
        # auto-clear timer redundant — cancel it so it doesn't fire again
        # later against whatever new content the user has copied since.
        if getattr(self, "_autoclear_after_id", None):
            try:
                self.root.after_cancel(self._autoclear_after_id)
            except Exception:
                pass
            self._autoclear_after_id = None
        self._autoclear_pending_text = None

        errors = []

        # 1. Tkinter CLIPBOARD
        try:
            self.root.clipboard_clear()
            self.root.update()
        except Exception as e:
            errors.append(f"Tkinter: {e}")

        # 2. Tkinter PRIMARY (X11 middle-click)
        try:
            self.root.selection_clear()
        except Exception:
            pass

        # 3. OS-native fallbacks
        if sys.platform == "win32":
            try:
                import ctypes
                from ctypes import wintypes
                user32 = ctypes.WinDLL("user32", use_last_error=True)
                if user32.OpenClipboard(None):
                    user32.EmptyClipboard()
                    user32.CloseClipboard()
            except Exception as e:
                errors.append(f"WinAPI: {e}")
        elif sys.platform == "darwin":
            try:
                subprocess.run(["pbcopy"], input=b"", check=True, timeout=2.0)
            except Exception as e:
                errors.append(f"pbcopy: {e}")
        else:  # Linux / *BSD
            # Try xclip first, then xsel
            cleared = False
            for cmd in (["xclip", "-selection", "clipboard", "-in"],
                        ["xsel", "--clipboard", "--input"]):
                if shutil.which(cmd[0]):
                    try:
                        subprocess.run(cmd, input=b"", check=True, timeout=2.0)
                        cleared = True
                        break
                    except Exception as e:
                        errors.append(f"{cmd[0]}: {e}")
            if not cleared:
                # Last resort: try wl-copy (Wayland)
                if shutil.which("wl-copy"):
                    try:
                        subprocess.run(["wl-copy", "--clear"], check=True, timeout=2.0)
                    except Exception as e:
                        errors.append(f"wl-copy: {e}")

        # Clear any text selection in our widgets so Ctrl+C cant re-copy old data
        try:
            if hasattr(self, "output_text"):
                self.output_text.tag_remove("sel", "1.0", tk.END)
                self.output_text.mark_set("insert", "1.0")
        except Exception:
            pass

        if hasattr(self, "clip_status"):
            if errors and not (sys.platform == "linux" and shutil.which("xclip") or shutil.which("xsel") or shutil.which("wl-copy")):
                self.clip_status.config(
                    text=f"Cleared (Tkinter). Install xclip/xsel/wl-copy for full system wipe.",
                    fg=self.theme["warning"]
                )
            else:
                self.clip_status.config(text="Clipboard cleared.", fg=self.theme["success"])

        # Also update generator tab status if visible
        if hasattr(self, "gen_clip_status"):
            self.gen_clip_status.config(text="Clipboard cleared.", fg=self.theme["success"])

    # ---------- Auto-clear controls (shown identically on both tabs) ----------
    def _build_autoclear_controls(self, parent, which):
        """Build the 'auto-clear clipboard after copy' checkbox + delay
        spinbox. `which` is 'gen' or 'enc' — used to keep two independent
        Tkinter variable sets (one per tab) mirrored to the same underlying
        current_values entries, since both tabs are built at once."""
        wrap = tk.Frame(parent, bg=self.theme["surface"])
        wrap.pack(fill=tk.X, padx=16, pady=(0, 10))

        enabled_var = tk.BooleanVar(value=self.current_values.get("autoclear_enabled", True))
        seconds_var = tk.IntVar(value=self.current_values.get("autoclear_seconds", 20))
        setattr(self, f"autoclear_enabled_var_{which}", enabled_var)
        setattr(self, f"autoclear_seconds_var_{which}", seconds_var)

        cb = tk.Checkbutton(
            wrap, text="Auto-clear clipboard after", variable=enabled_var,
            bg=self.theme["surface"], fg=self.theme["text"],
            selectcolor=self.theme["accent"], activebackground=self.theme["surface"],
            activeforeground=self.theme["text"], font=(self.font_family, 9, "bold"),
            anchor="w", padx=0,
            command=lambda: self._on_autoclear_change(which)
        )
        cb.pack(side=tk.LEFT)

        spin = tk.Spinbox(
            wrap, from_=5, to=300, width=4, textvariable=seconds_var,
            bg=self.theme["input_bg"], fg=self.theme["input_fg"], insertbackground=self.theme["input_fg"],
            font=(self.mono_family, 9), buttonbackground=self.theme["button_bg"], bd=0, relief=tk.FLAT,
            command=lambda: self._on_autoclear_change(which)
        )
        spin.pack(side=tk.LEFT, padx=(6, 4))
        seconds_var.trace_add("write", lambda *args: self._on_autoclear_change(which))

        tk.Label(wrap, text="seconds (best-effort \u2014 paste can't be reliably detected)",
                 font=(self.font_family, 8), bg=self.theme["surface"],
                 fg=self.theme["text_secondary"]).pack(side=tk.LEFT)

        if sys.platform not in ("win32", "darwin"):
            self._build_linux_exclusion_control(parent, which)

    def _build_linux_exclusion_control(self, parent, which):
        """Linux-only: opt-in checkbox for the xclip/xsel 'hide from KDE
        Klipper' write path. Off by default because that path forks a
        background helper process that must stay alive to answer paste
        requests — some distros/session managers reap that orphan after a
        few seconds, silently emptying the clipboard. The default path
        (our own long-running process holding the clipboard via Tkinter)
        doesn't have that failure mode, matching what already works
        reliably on Windows/macOS."""
        wrap = tk.Frame(parent, bg=self.theme["surface"])
        wrap.pack(fill=tk.X, padx=16, pady=(0, 10))

        var = tk.BooleanVar(value=self.current_values.get("linux_try_exclusion", False))
        setattr(self, f"linux_exclusion_var_{which}", var)

        cb = tk.Checkbutton(
            wrap, text="Try to hide copies from Linux clipboard managers (KDE Klipper, etc.)",
            variable=var, bg=self.theme["surface"], fg=self.theme["text"],
            selectcolor=self.theme["accent"], activebackground=self.theme["surface"],
            activeforeground=self.theme["text"], font=(self.font_family, 9, "bold"),
            anchor="w", padx=0,
            command=lambda: self._on_linux_exclusion_change(which)
        )
        cb.pack(anchor=tk.W)

        tk.Label(
            wrap, text="Experimental \u2014 on some distros this can make the clipboard "
                       "empty out on its own before you paste. Leave off if paste keeps failing.",
            font=(self.font_family, 8), bg=self.theme["surface"],
            fg=self.theme["text_secondary"], wraplength=380, justify=tk.LEFT
        ).pack(anchor=tk.W)

    def _on_linux_exclusion_change(self, which):
        """Mirror the Linux exclusion opt-in across both tabs, same pattern
        as _on_autoclear_change."""
        if self._syncing_autoclear:
            return
        self._syncing_autoclear = True
        try:
            var = getattr(self, f"linux_exclusion_var_{which}", None)
            if var is None:
                return
            enabled = var.get()
            self.current_values["linux_try_exclusion"] = enabled
            for other in ("gen", "enc"):
                if other == which:
                    continue
                other_var = getattr(self, f"linux_exclusion_var_{other}", None)
                if other_var is not None:
                    other_var.set(enabled)
        finally:
            self._syncing_autoclear = False

    def _on_autoclear_change(self, which):
        """Fired when either tab's auto-clear checkbox/spinbox changes.
        Updates current_values and mirrors the new value onto the other
        tab's controls (guarded against re-entrant trace callbacks)."""
        if self._syncing_autoclear:
            return
        self._syncing_autoclear = True
        try:
            enabled_var = getattr(self, f"autoclear_enabled_var_{which}", None)
            seconds_var = getattr(self, f"autoclear_seconds_var_{which}", None)
            if enabled_var is None or seconds_var is None:
                return

            enabled = enabled_var.get()
            try:
                seconds = int(seconds_var.get())
            except (tk.TclError, ValueError):
                seconds = self.current_values.get("autoclear_seconds", 20)
            seconds = max(5, min(300, seconds))

            self.current_values["autoclear_enabled"] = enabled
            self.current_values["autoclear_seconds"] = seconds

            for other in ("gen", "enc"):
                if other == which:
                    continue
                other_enabled = getattr(self, f"autoclear_enabled_var_{other}", None)
                other_seconds = getattr(self, f"autoclear_seconds_var_{other}", None)
                if other_enabled is not None:
                    other_enabled.set(enabled)
                if other_seconds is not None:
                    other_seconds.set(seconds)
        finally:
            self._syncing_autoclear = False

    # ---------- Theme switch ----------
    def switch_theme(self):
        new_theme = "light" if self.theme_name == "dark" else "dark"
        self.theme_name = new_theme
        self.theme = THEMES[new_theme]
        self.root.configure(bg=self.theme["bg"])

        saved_output = self.output_text.get(1.0, tk.END) if hasattr(self, "output_text") else ""
        saved_enc_result = self.enc_result_text.get(1.0, tk.END) if hasattr(self, "enc_result_text") else ""
        saved_enc_status = self.enc_status.cget("text") if hasattr(self, "enc_status") else ""
        saved_dec_status = self.dec_status.cget("text") if hasattr(self, "dec_status") else ""
        saved_shred_status = self.shred_status.cget("text") if hasattr(self, "shred_status") else ""
        saved_clip_status = self.clip_status.cget("text") if hasattr(self, "clip_status") else ""
        saved_gen_clip_status = self.gen_clip_status.cget("text") if hasattr(self, "gen_clip_status") else ""

        self.main_frame.destroy()
        self.main_frame = tk.Frame(self.root, bg=self.theme["bg"])
        self.main_frame.grid(row=0, column=0, sticky="nsew")

        self.build_ui()

        if saved_output.strip() and hasattr(self, "output_text"):
            self.output_text.config(state=tk.NORMAL)
            self.output_text.delete(1.0, tk.END)
            self.output_text.insert(tk.END, saved_output)
            self.output_text.config(state=tk.DISABLED)
            if self.generated_passwords:
                self.copy_btn.config(state=tk.NORMAL)
                self.save_btn.config(state=tk.NORMAL)
                self.encrypt_shred_btn.config(state=tk.NORMAL)

        if saved_enc_result.strip() and hasattr(self, "enc_result_text"):
            self.enc_result_text.config(state=tk.NORMAL)
            self.enc_result_text.delete(1.0, tk.END)
            self.enc_result_text.insert(tk.END, saved_enc_result)
            self.enc_result_text.config(state=tk.DISABLED)
            if self.last_encrypted_b64:
                self.enc_copy_btn.config(state=tk.NORMAL)
                self.enc_save_btn.config(state=tk.NORMAL)

        if hasattr(self, "enc_status"):
            self.enc_status.config(text=saved_enc_status)
        if hasattr(self, "dec_status"):
            self.dec_status.config(text=saved_dec_status)
        if hasattr(self, "shred_status"):
            self.shred_status.config(text=saved_shred_status)
        if hasattr(self, "clip_status"):
            self.clip_status.config(text=saved_clip_status)
        if hasattr(self, "gen_clip_status"):
            self.gen_clip_status.config(text=saved_gen_clip_status)

        self.update_pool_stats()
        self.show_tab(self.active_tab)
        self.check_enc_ready()
        self.check_dec_ready()
        self.check_shred_ready()

    # ---------- UI helpers ----------
    def _configure_styles(self):
        style = ttk.Style()
        try:
            style.theme_use("clam")
        except tk.TclError:
            pass
        style.configure(
            "Accent.Horizontal.TProgressbar",
            background=self.theme["accent"], troughcolor=self.theme["trough"],
            borderwidth=0, lightcolor=self.theme["accent"], darkcolor=self.theme["accent"],
        )

    def _style_scrolledtext(self, widget):
        for child in widget.winfo_children():
            if isinstance(child, tk.Scrollbar):
                child.configure(
                    bg=self.theme["border"], activebackground=self.theme["input_bg"],
                    troughcolor=self.theme["trough"],
                )

    def make_button(self, parent, text, kind="neutral", **pack_kwargs):
        """kind: accent | success | danger | neutral"""
        palette = {
            "accent": (self.theme["accent"], self.theme["accent_hover"], "#ffffff"),
            "success": (self.theme["success"], self.theme["success_hover"], "#ffffff"),
            "danger": (self.theme["danger"], self.theme["danger_hover"], "#ffffff"),
            "neutral": (self.theme["button_bg"], self.theme["input_bg"], "#ffffff"),
        }[kind]
        bg, hover, fg = palette

        # Ensure neutral buttons in light mode have enough contrast for white text
        if kind == "neutral" and self.theme_name == "light":
            bg, hover = "#4b5563", "#374151"

        btn = tk.Button(
            parent, text=text, font=(self.font_family, 11, "bold"),
            bd=0, padx=18, pady=9, bg=bg, fg=fg,
            activebackground=hover, activeforeground=fg,
            cursor="hand2", relief=tk.FLAT,
        )

        def on_enter(_e):
            if str(btn["state"]) != tk.DISABLED:
                btn.config(bg=hover)

        def on_leave(_e):
            if str(btn["state"]) != tk.DISABLED:
                btn.config(bg=bg)

        btn.bind("<Enter>", on_enter)
        btn.bind("<Leave>", on_leave)
        btn._base_bg = bg
        return btn

    def create_card(self, parent, title=None, subtitle=None):
        card = tk.Frame(
            parent, bg=self.theme["surface"], bd=0,
            highlightthickness=1, highlightbackground=self.theme["border"]
        )
        if title:
            head = tk.Frame(card, bg=self.theme["surface"])
            head.pack(fill=tk.X, padx=16, pady=(13, 8))
            tk.Label(head, text=title, font=(self.font_family, 12, "bold"),
                     bg=self.theme["surface"], fg=self.theme["text"]).pack(anchor=tk.W)
            if subtitle:
                tk.Label(head, text=subtitle, font=(self.font_family, 9),
                         bg=self.theme["surface"], fg=self.theme["text_secondary"]).pack(anchor=tk.W, pady=(2, 0))
            tk.Frame(card, bg=self.theme["border"], height=1).pack(fill=tk.X, padx=16, pady=(0, 10))
        return card

