        self.dec_btn.config(state=tk.NORMAL if ready else tk.DISABLED)

    def derive_key(self, password, salt):
        kdf = PBKDF2HMAC(
            algorithm=hashes.SHA256(),
            length=32,
            salt=salt,
            iterations=600000,
        )
        return kdf.derive(password.encode("utf-8"))

    def encrypt_file(self):
        path = self.enc_file_path.get()
        pwd = self.enc_pwd_var.get()
        if not path or len(pwd) < 8:
            return

        self.enc_status.config(text="Encrypting...", fg=self.theme["accent"])
        self.root.update()

        try:
            with open(path, "rb") as f:
                data = f.read()

            salt = os.urandom(16)
            iv = os.urandom(12)
            key = self.derive_key(pwd, salt)
            aesgcm = AESGCM(key)
            ct = aesgcm.encrypt(iv, data, None)

            combined = salt + iv + ct
            b64 = base64.b64encode(combined).decode("ascii")

            self.last_encrypted_b64 = b64
            self.last_encrypted_filename = Path(path).name + ".enc"

            # Show in text area
            self.enc_result_text.config(state=tk.NORMAL)
            self.enc_result_text.delete(1.0, tk.END)
            preview = b64[:1200] + "..." if len(b64) > 1200 else b64
            self.enc_result_text.insert(tk.END, preview + "\n")
            if len(b64) > 1200:
                self.enc_result_text.insert(tk.END, f"\n[Total length: {len(b64)} characters - use Copy or Save for full data]\n")
            self.enc_result_text.config(state=tk.DISABLED)

            self.enc_copy_btn.config(state=tk.NORMAL)
            self.enc_save_btn.config(state=tk.NORMAL)

            status_msg = "Encryption complete. Use Copy or Save below."
            status_fg = self.theme["success"]

            # Shred original if requested
            if self.shred_after_enc_var.get():
                try:
                    result = self.shred_file(path)
                    if result == "fallback":
                        status_msg = "Encrypted. Original file deleted (standard fallback, overwrite failed)."
                        status_fg = self.theme["warning"]
                        # Show FATAL SECURITY WARNING
                        messagebox.showwarning(
                            "FATAL SECURITY WARNING",
                            "Secure overwrite failed for the original file.\n\n"
                            "The file was removed using standard Python deletion only, "
                            "which may leave recoverable data on disk.\n\n"
                            "If this file contains sensitive data, manual secure deletion "
                            "(e.g., using shred, srm, or a secure erase tool) is strongly recommended."
                        )
                    else:
                        status_msg = "Encryption complete. Original file securely deleted."
                except Exception as e:
                    status_msg = f"Encrypted, but shred failed: {e}"
                    status_fg = self.theme["warning"]

            self.enc_status.config(text=status_msg, fg=status_fg)
        except Exception as e:
            self.enc_status.config(text=f"Error: {str(e)}", fg=self.theme["danger"])
            messagebox.showerror("Error", str(e))

    def copy_encrypted(self):
        if not self.last_encrypted_b64:
            return
        self.root.clipboard_clear()
        self.root.clipboard_append(self.last_encrypted_b64)
        messagebox.showinfo("Copied", "Encrypted base64 copied to clipboard.")

    def save_encrypted(self):
        if not self.last_encrypted_b64:
            return
        path = filedialog.asksaveasfilename(
            defaultextension=".enc",
            filetypes=[("Encrypted files", "*.enc"), ("All files", "*.*")],
            initialfile=self.last_encrypted_filename or "encrypted.enc"
        )
        if path:
            try:
                with open(path, "w", encoding="ascii") as f:
                    f.write(self.last_encrypted_b64)
                self.enc_status.config(text=f"Saved: {path}", fg=self.theme["success"])
                messagebox.showinfo("Saved", f"Encrypted file saved.\n\n{path}")
            except Exception as e:
                messagebox.showerror("Error", str(e))

    def decrypt_file(self):
        path = self.dec_file_path.get()
        pwd = self.dec_pwd_var.get()
        if not path or not pwd:
            return

        self.dec_status.config(text="Decrypting...", fg=self.theme["accent"])
        self.root.update()

        try:
            with open(path, "r", encoding="ascii") as f:
                b64 = f.read().strip()

            combined = base64.b64decode(b64)
            if len(combined) < 28:
                raise ValueError("Invalid file format")

            salt = combined[:16]
            iv = combined[16:28]
            ct = combined[28:]

            key = self.derive_key(pwd, salt)
            aesgcm = AESGCM(key)
            plain = aesgcm.decrypt(iv, ct, None)

            out_path = filedialog.asksaveasfilename(
                defaultextension="",
                filetypes=[("All files", "*.*")],
                initialfile=Path(path).stem
            )
            if out_path:
                with open(out_path, "wb") as f:
                    f.write(plain)
                self.dec_status.config(text=f"Saved: {out_path}", fg=self.theme["success"])
                messagebox.showinfo("Success", f"File decrypted and saved.\n\n{out_path}")
        except Exception as e:
            self.dec_status.config(text="Error: wrong password or corrupt file", fg=self.theme["danger"])
            messagebox.showerror("Error", "Decryption failed. Wrong password or corrupt file.")

    # ---------- Shred ----------
    def browse_shred_file(self):
        path = filedialog.askopenfilename(title="Select file to shred")
        if path:
            self.shred_file_path.set(path)
            self.check_shred_ready()

    def check_shred_ready(self):
        ready = bool(self.shred_file_path.get())
        self.shred_btn.config(state=tk.NORMAL if ready else tk.DISABLED)

    def shred_file_dialog(self):
        path = self.shred_file_path.get()
        if not path or not os.path.exists(path):
            return
        if not messagebox.askyesno(
            "Confirm Shred",
            f"Permanently shred this file?\n\n{path}\n\nThis action cannot be undone."
        ):
            return
        self.shred_status.config(text="Shredding...", fg=self.theme["accent"])
        self.root.update()
        try:
            result = self.shred_file(path)
            if result == "fallback":
                self.shred_status.config(
                    text="FATAL SECURITY WARNING: File deleted with standard fallback. Manual secure deletion required.",
                    fg=self.theme["danger"]
                )
                messagebox.showwarning(
                    "FATAL SECURITY WARNING",
                    "Secure overwrite failed for the selected file.\n\n"
                    "The file was removed using standard Python deletion only, "
                    "which may leave recoverable data on disk.\n\n"
                    "If this file contains sensitive data, manual secure deletion "
                    "(e.g., using shred, srm, or a secure erase tool) is strongly recommended."
                )
            else:
                self.shred_status.config(text="File securely shredded.", fg=self.theme["success"])
                self.shred_file_path.set("")
                self.check_shred_ready()
                messagebox.showinfo("Shred Complete", "File has been securely deleted.")
        except Exception as e:
            self.shred_status.config(text=f"Error: {str(e)}", fg=self.theme["danger"])
            messagebox.showerror("Error", str(e))

    def shred_file(self, path, passes=3):
        """Securely shred a file. Returns 'secure' or 'fallback'."""
        if not os.path.exists(path):
            raise FileNotFoundError(f"File not found: {path}")
        if os.path.isdir(path):
            raise IsADirectoryError(f"Cannot shred a directory: {path}")

        size = os.path.getsize(path)
        overwrite_ok = True

        # Secure overwrite
        if size > 0:
            try:
                chunk_size = 1024 * 1024
                with open(path, "r+b") as f:
                    for _ in range(passes):
                        f.seek(0)
                        written = 0
                        while written < size:
                            to_write = min(chunk_size, size - written)
                            f.write(os.urandom(to_write))
                            written += to_write
                        f.flush()
                        try:
                            os.fsync(f.fileno())
                        except OSError:
                            pass
                    # Final zero pass
                    f.seek(0)
                    written = 0
                    while written < size:
                        to_write = min(chunk_size, size - written)
                        f.write(b'\x00' * to_write)
                        written += to_write
                    f.flush()
                    try:
                        os.fsync(f.fileno())
                    except OSError:
                        pass
            except Exception:
                overwrite_ok = False

        # Deletion fallback (always attempt standard Python deletion)
        try:
            if sys.platform == "win32":
                os.chmod(path, stat.S_IWRITE)
            os.remove(path)
        except Exception as e:
            action = "overwritten" if overwrite_ok else "overwrite failed"
            raise RuntimeError(f"File {action} but could not be removed: {e}")

        return "secure" if overwrite_ok else "fallback"


