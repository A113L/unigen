# ---------- Self-source character set ----------
def load_self_source_chars():
    """Read this script's own source file and return its unique, printable,
    non-whitespace characters. Kept dynamic (rather than hard-coded) so the
    character set always matches whatever this file actually contains."""
    try:
        src_path = os.path.abspath(__file__)
        with open(src_path, "r", encoding="utf-8", errors="ignore") as f:
            content = f.read()
    except Exception:
        return ""
    seen = set()
    result = []
    for ch in content:
        if ch in ("\n", "\r", "\t", " "):
            continue
        if not ch.isprintable():
            continue
        if ch not in seen:
            seen.add(ch)
            result.append(ch)
    return "".join(sorted(result))


