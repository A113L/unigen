    # ---------- Secure clipboard ----------
    def copy_to_clipboard_secure(self, text, status_label=None):
        """Copy text to clipboard and schedule an automatic clear 30 seconds later."""
        self.root.clipboard_clear()
        self.root.clipboard_append(text)
        self.root.update()

        if status_label is not None:
            status_label.config(
                text="Copied.",
                fg=self.theme["accent"]
            )

        if self._clipboard_clear_job is not None:
            try:
                self.root.after_cancel(self._clipboard_clear_job)
            except Exception:
                pass

        def _clear():
            should_clear = False
            try:
                current = self.root.clipboard_get()
                should_clear = current == text
            except Exception:
                # On Linux/X11 we often can't read the clipboard reliably.
                # Secure default: clear anyway in case it is still our password.
                should_clear = True

            if should_clear:
                self.root.clipboard_clear()
            self._clipboard_clear_job = None

        self._clipboard_clear_job = self.root.after(CLIPBOARD_CLEAR_MS, _clear)

