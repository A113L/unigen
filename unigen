    def switch_tab(self, tab):
        self.active_tab = tab
        for name, btn in self.tab_buttons.items():
            if name == tab:
                btn.config(bg=self.theme["accent"], fg="white")
            else:
                btn.config(bg=self.theme["card_bg"], fg=self.theme["text_secondary"])
        self.show_tab(tab)

    def show_tab(self, tab):
        if tab == "gen":
            self.gen_frame.pack(fill=tk.BOTH, expand=True)
            self.enc_frame.pack_forget()
        else:
            self.gen_frame.pack_forget()
            self.enc_frame.pack(fill=tk.BOTH, expand=True)

